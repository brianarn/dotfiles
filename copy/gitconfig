# LOCAL CONFIG

# DO NOT EDIT BELOW THIS LINE
[user]
	name = Brian Sinclair
	email = brianarn@gmail.com

[core]
	editor = nvim

[color]
	diff = auto
	status = auto
	branch = auto
	interactive = auto

[push]
	default = simple

[pull]
	rebase = true

[diff]
	renames = true
	indentHeuristic = on

[branch]
	autosetupmerge = true

[merge]
	summary = true
	conflictstyle = diff3

[rebase]
	autosquash = true
	autostash = true

[rerere]
	enabled = 1

[log]
	mailmap = true

[init]
	defaultBranch = main

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[alias]
	co = checkout
	cp = cherry-pick
	last = log -1 HEAD
	lg = log --all --graph --abbrev-commit --date=relative --pretty=format:'%C(bold blue)%h - %C(reset)%C(green)(%ar)%C(reset) - %s %C(dim)- %an%C(reset)%C(yellow)%d'
	lgb = log --graph --abbrev-commit --date=relative --pretty=format:'%C(bold blue)%h - %C(reset)%C(green)(%ar)%C(reset) - %s %C(dim)- %an%C(reset)%C(yellow)%d'
	nit = commit --amend --no-edit
	pf = push --force-with-lease
	pg = log --pretty=oneline --graph
	st = status
	tree = log --graph --decorate --pretty=oneline --abbrev-commit
	track = !sh -c 'git branch --track "$0" "origin/$0" && git checkout "$0"'
	whatis = show -s --pretty='tformat:%h (%s, %ad)' --date=short
	cleanup-branches = !sh -c 'git branch --merged | grep -v ^* | xargs -n 1 git branch -d'
